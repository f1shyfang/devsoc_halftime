# DebateConnect environment variables
# Copy to .env.local and fill in real values for local dev.

# --- Supabase (unused at V1; auth is a V2 TODO) ---
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# --- Upstash Redis (room state, matchmaking queue) ---
# https://console.upstash.com/  →  Create database  →  "REST API" section
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Pusher (matchmaking + judgment broadcast) ---
# https://dashboard.pusher.com/  →  Channels app  →  App Keys
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us2
# Public mirrors of the same key/cluster (client-side subscribe)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=us2

# --- Anthropic (prompt generation + judge) ---
ANTHROPIC_API_KEY=

# --- OpenAI (Whisper transcription) ---
OPENAI_API_KEY=

# --- Daily.co (video) ---
# Subdomain is the part before .daily.co in your Daily URL.
NEXT_PUBLIC_DAILY_SUBDOMAIN=
# Optional: only needed if you create rooms programmatically rather than using
# auto-create. With auto-create on, the iframe URL alone is enough.
DAILY_API_KEY=

# --- Admin seed (debug endpoint auth) ---
# Any random string — used in `x-admin-secret` header.
ADMIN_SECRET=
